# ============= API KEYS =============
# Get Claude API Key: https://console.anthropic.com/
CLAUDE_API_KEY=

# Get Gemini API Key: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=

# You only need ONE of the above API keys to start!

# ============= SERVER CONFIG =============
PORT=3000
NODE_ENV=production

# ============= SECURITY =============
# In production, replace * with your actual domain
# Example: https://your-canva-code-url.com,https://www.canva.com
ALLOWED_ORIGINS=*

# Rate limiting (requests per 15 minutes per IP)
RATE_LIMIT_MAX=100

# ============= DEFAULT SETTINGS =============
DEFAULT_AI_PROVIDER=gemini
